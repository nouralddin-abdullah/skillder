<?xml version="1.0" encoding="utf-8"?>
<!--
  Allows plain HTTP traffic to local-network dev hosts so a real phone can
  hit the laptop's API server (e.g. http://192.168.1.17:3000) during
  development. Production traffic must continue to use HTTPS — anything
  not listed here is blocked from cleartext.
-->
<network-security-config>
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
    <domain-config cleartextTrafficPermitted="true">
        <!-- Localhost / Android emulator bridge -->
        <domain includeSubdomains="true">localhost</domain>
        <domain includeSubdomains="true">127.0.0.1</domain>
        <domain includeSubdomains="true">10.0.2.2</domain>
        <!-- Common LAN ranges for dev laptops on Wi-Fi -->
        <domain-suffix includeSubdomains="true">.local</domain-suffix>
        <domain-suffix>192.168.0.0</domain-suffix>
        <domain-suffix>192.168.1.0</domain-suffix>
        <!-- Fallback: any 192.168.* / 10.* / 172.16-31.* address -->
        <domain includeSubdomains="false">192.168.1.17</domain>
    </domain-config>
</network-security-config>
